pipeline {
    agent any

    stages {
        stage('Build Java App') {
            steps {
                sh 'mvn clean package'
            }
        }
    }
}pipeline {
    agent {
        docker {
           image 'maven:3.9.9-eclipse-temurin-17'
        }
    }

    stages {
        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }
    }
}
